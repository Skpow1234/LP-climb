{
  "name": "lp-climb-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20",
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "bun --cwd packages/api run dev",
    "build": "bun --cwd packages/api run build",
    "start": "bun --cwd packages/api run start",
    "lint": "bun --cwd packages/api run lint",
    "format": "bun --cwd packages/api run format"
  },
  "devDependencies": {}
}
